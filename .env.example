# Cortex WeChat Agent — Environment Configuration
# Copy to ~/.cortex/env and fill in values.
# The launchd services source this file automatically.

# --- Cortex API ---
CORTEX_BASE_URL=http://127.0.0.1:8420/api/v1
CORTEX_WORKSPACE=default
# CORTEX_API_TOKEN=           # Optional: API token if Cortex auth is enabled

# --- LLM Semantic Routing (optional, falls back to regex when absent) ---
# LLM_BASE_URL=https://api.minimaxi.chat/v1
# LLM_API_KEY=your-key-here
# LLM_MODEL=MiniMax-M2.7
# LLM_TIMEOUT_MS=15000        # Default: 6000

# --- iLink Agent ---
# DISPATCH_INTERVAL_MS=60000  # Notification push interval (default: 60s)
# ALLOWED_SENDER_IDS=         # Comma-separated WeChat user IDs (auto-locks first sender if empty)

# --- Telegram Agent (optional) ---
# TELEGRAM_BOT_TOKEN=         # From @BotFather
# TELEGRAM_ALLOWED_CHAT_IDS=  # Comma-separated chat IDs
